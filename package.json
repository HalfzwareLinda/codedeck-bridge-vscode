{
  "name": "codedeck-bridge",
  "displayName": "Codedeck Bridge",
  "description": "Bridge Claude Code sessions to Codedeck mobile app over Nostr relays",
  "version": "0.3.11",
  "publisher": "halfzwarelinda",
  "repository": {
    "type": "git",
    "url": "https://github.com/HalfzwareLinda/codedeck-bridge-vscode"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codedeck.quickMenu",
        "title": "Codedeck: Quick Menu"
      },
      {
        "command": "codedeck.pair",
        "title": "Codedeck: Pair Phone"
      },
      {
        "command": "codedeck.status",
        "title": "Codedeck: Show Status"
      },
      {
        "command": "codedeck.disconnect",
        "title": "Codedeck: Disconnect All"
      }
    ],
    "configuration": {
      "title": "Codedeck Bridge",
      "properties": {
        "codedeck.relays": {
          "type": "array",
          "default": [
            "wss://relay2.descendant.io",
            "wss://relay.primal.net",
            "wss://relay.nostr.band",
            "wss://nos.lol"
          ],
          "description": "Nostr relay URLs for phone communication"
        },
        "codedeck.machineName": {
          "type": "string",
          "default": "",
          "description": "Display name for this machine (defaults to hostname)"
        },
        "codedeck.autoApproveRetry": {
          "type": "boolean",
          "default": true,
          "description": "Retry auto-approve keypresses when tool calls aren't accepted within 1.5s (disable if excess '1' characters appear in terminal)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --target=node18 --sourcemap",
    "watch": "esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --target=node18 --sourcemap --watch",
    "typecheck": "tsc --noEmit",
    "package": "vsce package",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.24.2",
    "typescript": "^5.5.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "nostr-tools": "^2.23.1",
    "qrcode-svg": "^1.1.0"
  }
}
